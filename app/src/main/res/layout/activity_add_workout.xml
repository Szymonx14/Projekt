<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="@color/primary"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="➕ Nowy Trening"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- NAZWA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nazwa treningu"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etWorkoutName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="np. Trening nóg"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- TYP -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Typ treningu"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- DATA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="np. 2024-01-15"
            android:background="@color/surface"
            android:padding="12dp"
            android:focusable="false"
            android:layout_marginBottom="16dp"/>

        <!-- CZAS TRWANIA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Czas trwania (minuty)"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="np. 60"
            android:inputType="number"
            android:background="@color/surface"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- NOTATKI -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notatki (opcjonalne)"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="np. Dobry trening, zwiększyć ciężar"
            android:background="@color/surface"
            android:padding="12dp"
            android:gravity="top"
            android:layout_marginBottom="24dp"/>

        <!-- PRZYCISK -->
        <Button
            android:id="@+id/btnSaveWorkout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="💾 Zapisz Trening"
            android:textSize="16sp"
            android:backgroundTint="@color/primary"
            android:textColor="@color/white"/>

    </LinearLayout>
</ScrollView>